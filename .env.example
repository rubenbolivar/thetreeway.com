# TheTreeWay — environment variables (REFACTOR-STRATEGY.md §9)
# Copy to .env.local and fill real values. .env.local is gitignored.

# Public site URL (no trailing slash). Used for canonical, OG, sitemap.
NEXT_PUBLIC_SITE_URL=https://thetreeway.com

# Resend (contact form). FROM must be on the verified domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=TheTreeWay <hola@thetreeway.com>
RESEND_TO=rubenbe9@gmail.com

# Cal.com (diagnostic booking embed): cal.com/<user>/<event>
CAL_COM_USERNAME=ruben-bolivar
CAL_COM_EVENT=diagnostico

# Plausible analytics (privacy-friendly; NO Google Analytics — §2)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=thetreeway.com
